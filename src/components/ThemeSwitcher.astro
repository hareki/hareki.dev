---
import CheckIcon from '@tabler/icons/outline/check.svg';
import PaletteIcon from '@tabler/icons/outline/palette.svg';

import { Popover, PopoverContent } from '@/components/starwind/popover';
import {
  Tooltip,
  TooltipContent,
  TooltipTrigger,
} from '@/components/starwind/tooltip';

import HeaderButton from './HeaderButton.astro';
import Button from './starwind/button';

const FLAVORS = [
  { value: 'latte', label: 'Latte' },
  { value: 'frappe', label: 'Frappé' },
  { value: 'macchiato', label: 'Macchiato' },
  { value: 'mocha', label: 'Mocha' },
] as const;

const ACCENTS = [
  'Rosewater',
  'Flamingo',
  'Pink',
  'Mauve',
  'Red',
  'Maroon',
  'Peach',
  'Yellow',
  'Green',
  'Teal',
  'Sky',
  'Sapphire',
  'Blue',
  'Lavender',
] as const;

const accentMiddleIndex = Math.floor(ACCENTS.length / 2);
---

<Popover class='group/popover'>
  <HeaderButton
    icon={PaletteIcon}
    label='Theme'
    data-slot='popover-trigger'
    class='
      group-data-[state=open]/popover:bg-primary/10
      group-data-[state=open]/popover:text-primary
    '
  />

  <PopoverContent
    side='bottom'
    align='end'
    aria-label='Theme Settings'
    class='p-3'
  >
    <div data-theme-switcher>
      <div class='mb-1 text-xs text-muted-foreground'>FLAVOR</div>
      <div class='grid grid-cols-2 gap-2'>
        {
          FLAVORS.map(({ value, label }) => (
            <Button
              variant='secondary'
              size='sm'
              class='text-sm text-secondary-foreground transition-all'
              data-flavor={value}
            >
              {label}
            </Button>
          ))
        }
      </div>

      <div class='mt-6 mb-1 text-xs text-muted-foreground'>ACCENT</div>
      <div class='grid grid-cols-7 place-items-center gap-3'>
        {
          ACCENTS.map((label, index) => {
            const value = label.toLowerCase();

            return (
              <Tooltip>
                <TooltipTrigger>
                  <button
                    class='
                      flex-center size-7 bouncy-click rounded-full
                      transition-all
                    '
                    style={`background-color: var(--ctp-${value})`}
                    data-accent={value}
                    aria-label={`Select ${label} accent`}
                  >
                    <CheckIcon
                      class='
                        hidden size-4 animate-in text-background zoom-in-50
                      '
                      data-check
                    />
                  </button>
                </TooltipTrigger>
                <TooltipContent
                  sideOffset={16}
                  side={index < accentMiddleIndex ? 'top' : 'bottom'}
                >
                  {label}
                </TooltipContent>
              </Tooltip>
            );
          })
        }
      </div>
    </div>
  </PopoverContent>
</Popover>

<script>
  class ThemeSwitcherHandler {
    private flavorButtons: NodeListOf<HTMLElement>;
    private accentButtons: NodeListOf<HTMLElement>;
    private abortController: AbortController;

    constructor(container: HTMLElement) {
      this.abortController = new AbortController();
      this.flavorButtons =
        container.querySelectorAll<HTMLElement>('[data-flavor]');
      this.accentButtons =
        container.querySelectorAll<HTMLElement>('[data-accent]');
      this.setupEvents();
      this.syncUI();
    }

    private getCurrentFlavor(): string | undefined {
      const match =
        document.documentElement.className.match(/ctp-flavor-(\S+)/);
      if (match?.[1]) {
        return match[1];
      }

      console.error(`Flavor class should've been set on startup`);
      return undefined;
    }

    private getCurrentAccent(): string | undefined {
      const match =
        document.documentElement.className.match(/ctp-accent-(\S+)/);
      if (match?.[1]) {
        return match[1];
      }

      console.error(`Accent class should've been set on startup`);
      return undefined;
    }

    private setFlavor(flavor: string) {
      const html = document.documentElement;
      html.className = html.className.replace(/\bctp-flavor-\S+/g, '');
      html.classList.add(`ctp-flavor-${flavor}`);
      localStorage.setItem('ctp-flavor', flavor);
      this.syncUI();
    }

    private setAccent(accent: string) {
      const html = document.documentElement;
      html.className = html.className.replace(/\bctp-accent-\S+/g, '');
      html.classList.add(`ctp-accent-${accent}`);
      localStorage.setItem('ctp-accent', accent);
      this.syncUI();
    }

    private syncUI() {
      const currentFlavor = this.getCurrentFlavor();
      const currentAccent = this.getCurrentAccent();

      this.flavorButtons.forEach((btn) => {
        const isSelected = btn.dataset.flavor === currentFlavor;
        btn.classList.toggle('ring-2', isSelected);
        btn.classList.toggle('ring-primary', isSelected);
        btn.classList.toggle('text-primary', isSelected);
      });

      this.accentButtons.forEach((btn) => {
        const isSelected = btn.dataset.accent === currentAccent;
        btn.classList.toggle('ring-2', isSelected);
        btn.classList.toggle('ring-offset-1', isSelected);
        btn.classList.toggle('ring-offset-background', isSelected);
        btn.classList.toggle('ring-foreground', isSelected);

        const check = btn.querySelector<HTMLElement>('[data-check]');
        if (check) {
          check.classList.toggle('hidden', !isSelected);
        }
      });
    }

    private setupEvents() {
      const signal = this.abortController.signal;

      this.flavorButtons.forEach((btn) => {
        btn.addEventListener(
          'click',
          () => {
            if (btn.dataset.flavor) {
              this.setFlavor(btn.dataset.flavor);
            }
          },
          { signal },
        );
      });

      this.accentButtons.forEach((btn) => {
        btn.addEventListener(
          'click',
          () => {
            if (btn.dataset.accent) {
              this.setAccent(btn.dataset.accent);
            }
          },
          { signal },
        );
      });
    }

    destroy() {
      this.abortController.abort();
    }
  }

  let instances: ThemeSwitcherHandler[] = [];

  const initThemeSwitcher = () => {
    document
      .querySelectorAll<HTMLElement>('[data-theme-switcher]')
      .forEach((container) => {
        instances.push(new ThemeSwitcherHandler(container));
      });
  };

  const destroyThemeSwitcher = () => {
    instances.forEach((instance) => instance.destroy());
    instances = [];
  };

  initThemeSwitcher();
  document.addEventListener('astro:before-swap', destroyThemeSwitcher);
  document.addEventListener('astro:after-swap', initThemeSwitcher);
</script>
