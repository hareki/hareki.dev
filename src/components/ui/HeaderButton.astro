---
import { cn } from 'tailwind-variants';

import Button from '@/components/starwind/button';
import {
  Tooltip,
  TooltipContent,
  TooltipTrigger,
} from '@/components/starwind/tooltip';

import NewTabIndicator from './NewTabIndicator.astro';

import type { ButtonProps } from '../starwind/button/Button.astro';
import type { SvgComponent } from 'astro/types';

interface Props extends ButtonProps {
  icon: SvgComponent;
  label: string;
}

const { icon: Icon, label, class: className, ...rest } = Astro.props;
const hasChevron = !!rest.chevron;
const isOpenInNewTab = rest.href && rest.target === '_blank';
---

<Tooltip>
  <TooltipTrigger>
    <!-- Set to size='md' when container size is greater than @3xl, the 2-buttons hack have too many drawbacks and side effects...  -->
    <Button
      variant='ghost'
      size='icon'
      class={cn(
        '@3xl:w-auto @3xl:px-3.5',
        'group relative',
        className,
        hasChevron && 'w-auto px-2.25',
      )}
      {...rest}
    >
      <Icon class='@3xl:size-5' />
      <span class='
        hidden
        @3xl:inline
      '>{label}</span>
      {isOpenInNewTab && <NewTabIndicator />}
    </Button>
  </TooltipTrigger>
  <!-- Can't use container query since this component is rendered outside of the container (header) -->
  <TooltipContent class='md:hidden'>{label}</TooltipContent>
</Tooltip>
