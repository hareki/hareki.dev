---
import { MAIN_MODULES } from '@/data/beyond-work';
import { getLanguageStats, getRecentCommitDetails } from '@/lib/github';
import { getFormattedDate } from '@/utils/date';

import Badge from '../Badge.astro';
import StandaloneLink from '../StandaloneLink.astro';
import SubsectionTitle from '../SubsectionTitle.astro';

interface Props {
  repoFullName: string;
  commitLimit: number;
}

Astro.cache.set({
  maxAge: 900,
  swr: 60,
});

const { repoFullName, commitLimit } = Astro.props;
const [commits, languages] = await Promise.all([
  getRecentCommitDetails(repoFullName, commitLimit),
  getLanguageStats(repoFullName),
]);
---

<div class='rounded-md bg-inner-box p-2 text-sm'>
  <SubsectionTitle> Recent Commits </SubsectionTitle>
  <div class='mb-2 flex flex-col gap-1'>
    {
      commits.map((commit) => (
        <a
          href={commit.commitUrl}
          target='_blank'
          rel='noopener noreferrer'
          class='
            flex w-full bouncy-click items-center justify-between gap-1.5
            rounded-xs p-1.5 text-subtext1-foreground
            hover:bg-primary/10 hover:text-primary
            hocus:scale-[100.5%]
          '
        >
          <span class='truncate'>{commit.commitMessage}</span>

          <span class='flex gap-2 whitespace-nowrap'>
            <span class='whitespace-nowrap'>
              <span class='text-success'>+{commit.linesAdded}</span>
              <span class='text-error'>-{commit.linesDeleted}</span>
            </span>
            <span class='text-border'>—</span>
            <span class='text-subtext0-foreground'>
              <span>{getFormattedDate(commit.createdAt)}</span>
            </span>
          </span>
        </a>
      ))
    }
  </div>

  <div class='flex justify-between gap-4'>
    <div>
      <SubsectionTitle> Languages </SubsectionTitle>
      <div class='flex gap-2'>
        {
          languages.map(({ name, percent }) => (
            <Badge extraInfo={`${percent}%`}>{name}</Badge>
          ))
        }
      </div>
    </div>

    <div>
      <SubsectionTitle> Main Modules </SubsectionTitle>
      <div class='flex gap-2'>
        {
          MAIN_MODULES.map(({ name, url }) => (
            <StandaloneLink href={url}>{name}</StandaloneLink>
          ))
        }
      </div>
    </div>
  </div>
</div>
