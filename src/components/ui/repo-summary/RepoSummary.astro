---
import RepoSummaryContent from './RepoSummaryContent.astro';
import RepoSummarySkeleton from './RepoSummarySkeleton.astro';

interface Props {
  repoFullName: string;
  commitLimit: number;
}

const { repoFullName, commitLimit } = Astro.props;
---

<RepoSummaryContent
  server:defer
  repoFullName={repoFullName}
  commitLimit={commitLimit}
>
  <RepoSummarySkeleton slot='fallback' />
</RepoSummaryContent>
