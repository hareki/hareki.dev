---
import RepoSummaryContent from './RepoSummaryContent.astro';
import RepoSummarySkeleton from './RepoSummarySkeleton.astro';

interface Props {
  repoFullName: string;
}

const { repoFullName } = Astro.props;
const commitLimit = 4;
---

<RepoSummaryContent server:defer {repoFullName} {commitLimit}>
  <RepoSummarySkeleton slot='fallback' {commitLimit} />
</RepoSummaryContent>
