---
import ChevronDownIcon from '@tabler/icons/outline/chevron-down.svg';
import { tv, type VariantProps } from 'tailwind-variants';

import type { HTMLAttributes } from 'astro/types';

type ChevronProps = {
  orientation: 'up' | 'down';
  size?: 'md';
};

export interface ButtonProps
  extends
    HTMLAttributes<'button'>,
    Omit<HTMLAttributes<'a'>, 'type'>,
    VariantProps<typeof button> {
  chevron?: ChevronProps;
}

type Props = ButtonProps;

const { variant, size, class: className, chevron, ...rest } = Astro.props;

const chevronClass = tv({
  variants: {
    size: { md: 'size-3.5' },
  },
  defaultVariants: { size: 'md' },
});

export const button = tv({
  base: [
    `
      inline-flex bouncy-click items-center justify-center gap-1.5 rounded-md
      font-bold whitespace-nowrap
    `,
    '[&_svg]:pointer-events-none [&_svg]:shrink-0',
    `
      outline-none
      focus-visible:ring-3
    `,
    'disabled:pointer-events-none disabled:opacity-50',
    `
      aria-invalid:border-error
      aria-invalid:focus-visible:ring-error/40
    `,
  ],
  variants: {
    variant: {
      default: `
        bg-foreground text-background
        hover:bg-foreground/90
        focus-visible:ring-outline/50
      `,
      primary: `
        bg-primary text-primary-foreground
        hover:bg-primary/90
        focus-visible:ring-primary/50
      `,
      secondary: `
        bg-secondary text-secondary-foreground
        hover:bg-secondary/90
        focus-visible:ring-secondary-focus/50
      `,
      outline: `
        border bg-background shadow-xs
        hover:bg-muted hover:text-foreground
        focus-visible:border-outline focus-visible:ring-outline/50
        dark:border-input dark:bg-input/30
        dark:hover:bg-input/50
      `,
      ghost: `
        hover:bg-primary/10 hover:text-primary
        focus-visible:ring-outline/50
      `,
      info: `
        bg-info text-info-foreground
        hover:bg-info/90
        focus-visible:ring-info/50
      `,
      success: `
        bg-success text-success-foreground
        hover:bg-success/90
        focus-visible:ring-success/50
      `,
      warning: `
        bg-warning text-warning-foreground
        hover:bg-warning/90
        focus-visible:ring-warning/50
      `,
      error: `
        bg-error text-error-foreground
        hover:bg-error/90
        focus-visible:ring-error/50
      `,
    },
    size: {
      sm: `
        h-8.5 px-3.5 text-sm
        has-[>svg]:px-2.5
        [&_svg:not([class*='size-'])]:size-4
      `,
      md: `
        h-10.5 px-4.5 text-base
        has-[>svg]:px-3.5
        [&_svg:not([class*='size-'])]:size-5
      `,
      lg: `
        h-11.5 px-7.5 text-lg
        has-[>svg]:px-5.5
        [&_svg:not([class*='size-'])]:size-5.5
      `,
      'icon-sm': `
        size-8.5
        [&_svg:not([class*='size-'])]:size-5
      `,
      icon: `
        size-10.5
        [&_svg:not([class*='size-'])]:size-6
      `,
      'icon-lg': `
        size-11.5
        [&_svg:not([class*='size-'])]:size-6.5
      `,
    },
  },
  defaultVariants: { variant: 'default', size: 'md' },
});

const Tag = Astro.props.href ? 'a' : 'button';
---

<Tag
  class={button({ variant, size, class: className })}
  data-slot='button'
  {...rest}
>
  <slot />
  {
    chevron && (
      <ChevronDownIcon
        class={chevronClass({
          size: chevron.size,
          // PERF: Save bundle size by reusing icon
          class: chevron.orientation === 'up' && 'rotate-180',
        })}
      />
    )
  }
</Tag>
