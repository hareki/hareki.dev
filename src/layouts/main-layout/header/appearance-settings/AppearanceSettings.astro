---
import { Popover } from '@/components/starwind/popover';

import AppearanceSettingsPopoverContent from './AppearanceSettingsPopoverContent.astro';
import AppearanceSettingsPopoverTrigger from './AppearanceSettingsPopoverTrigger.astro';
---

<Popover class='group'>
  <AppearanceSettingsPopoverTrigger />
  <AppearanceSettingsPopoverContent />
</Popover>

<script>
  import { AppearanceController } from './AppearanceSettingsController';

  let instances: AppearanceController[] = [];

  const initController = () => {
    document
      .querySelectorAll<HTMLElement>('[data-appearance-controller]')
      .forEach((container) => {
        instances.push(new AppearanceController(container));
      });
  };

  const destroyController = () => {
    instances.forEach((instance) => instance.destroy());
    instances = [];
  };

  initController();
  document.addEventListener('astro:before-swap', destroyController);
  document.addEventListener('astro:after-swap', initController);
</script>
