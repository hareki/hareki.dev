---
import BaseSkeleton from '@/components/starwind/skeleton/Skeleton.astro';

import { GAP, ROW_HEIGHT } from './constants';

interface Props {
  limit: number;
}

const { limit } = Astro.props;
---

<!-- FIXME: Too hacky to get the skeleton match the innerbox -->
<BaseSkeleton
  style={`height: calc(${ROW_HEIGHT} * ${limit} + ${GAP} * (${limit} - 1) + 1rem)`}
  class='w-full'
/>
