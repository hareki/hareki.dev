---
import '@/styles/index.css';
import boldFont from '@/assets/fonts/MapleMonoNL-Bold.woff2';
import regularFont from '@/assets/fonts/MapleMonoNL-Regular.woff2';

import Footer from './Footer.astro';
import Header from './Header.astro';

interface Props {
  title?: string;
}
const { title } = Astro.props;
const baseTitle = 'Hareki';
---

<!doctype html>
<html lang='en' class='font-display'>
  <head>
    <script is:inline>
      (function () {
        const d = document.documentElement;
        let fl = localStorage.getItem('ctp-flavor');
        let ac = localStorage.getItem('ctp-accent');
        const mq = matchMedia('(prefers-color-scheme:dark)');

        function setFlavor(f) {
          d.className = d.className.replace(/\bctp-flavor-\S+/g, '');
          d.classList.add('ctp-flavor-' + f);
        }

        if (!fl) fl = mq.matches ? 'mocha' : 'latte';
        if (!ac) ac = 'blue';
        d.classList.add('ctp-flavor-' + fl, 'ctp-accent-' + ac);

        mq.addEventListener('change', function (e) {
          if (!localStorage.getItem('ctp-flavor')) {
            setFlavor(e.matches ? 'mocha' : 'latte');
          }
        });
      })();
    </script>
    <link href={regularFont} rel='preload' type='font/woff2' as='font' crossorigin />
    <link href={boldFont} rel='preload' type='font/woff2' as='font' crossorigin />
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <!-- <link rel='icon' href='/favicon.ico' /> -->
    <meta name='generator' content={Astro.generator} />
    <title>{title ? `${title} | ${baseTitle}` : baseTitle}</title>
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
