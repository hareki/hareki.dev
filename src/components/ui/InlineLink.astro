---
type Props = astroHTML.JSX.AnchorHTMLAttributes;
const { ...rest } = Astro.props;
---

<a
  target='_blank'
  rel='noopener noreferrer'
  class='
    group relative inline-flex rounded-xs text-primary underline
    underline-offset-2 transition-all
    hover:bg-primary hover:text-background hover:no-underline
  '
  {...rest}
  ><slot />
</a>
