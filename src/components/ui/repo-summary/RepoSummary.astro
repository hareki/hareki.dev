---
import RepoSummaryContent from './RepoSummaryContent.astro';
import RepoSummarySkeleton from './RepoSummarySkeleton.astro';

interface Props {
  repoFullName: string;
}

const { repoFullName } = Astro.props;
---

<RepoSummaryContent server:defer repoFullName={repoFullName} commitLimit={5}>
  <RepoSummarySkeleton slot='fallback' />
</RepoSummaryContent>
