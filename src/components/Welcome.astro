---
import Button from './starwind/button';
---

<div id='container'>
  <main>
    <section id='hero'>
      <Button>test</Button>
      <!-- Theme preview swatch -->
      <div
        class='
          mt-6 w-full max-w-xl space-y-4 rounded-xl border border-border
          bg-background p-5
        '
      >
        <h2 class='text-lg font-semibold text-foreground'>Theme Preview</h2>

        <div class='flex flex-wrap gap-2'>
          <span
            class='
              rounded-md bg-primary px-3 py-1.5 text-sm font-medium
              text-primary-foreground
            '
            >Primary</span
          >
          <span
            class='
              rounded-md bg-secondary px-3 py-1.5 text-sm font-medium
              text-secondary-foreground
            '
            >Secondary</span
          >
          <span
            class='
              rounded-md bg-muted px-3 py-1.5 text-sm font-medium
              text-muted-foreground
            '
            >Muted</span
          >
          <span
            class='
              rounded-md bg-accent px-3 py-1.5 text-sm font-medium
              text-accent-foreground
            '
            >Accent</span
          >
        </div>

        <div class='flex flex-wrap gap-2'>
          <span
            class='
              rounded-md bg-info px-3 py-1.5 text-sm font-medium
              text-info-foreground
            '
            >Info</span
          >
          <span
            class='
              rounded-md bg-success px-3 py-1.5 text-sm font-medium
              text-success-foreground
            '
            >Success</span
          >
          <span
            class='
              rounded-md bg-warning px-3 py-1.5 text-sm font-medium
              text-warning-foreground
            '
            >Warning</span
          >
          <span
            class='
              rounded-md bg-error px-3 py-1.5 text-sm font-medium
              text-error-foreground
            '
            >Error</span
          >
        </div>

        <div class='rounded-lg border border-border bg-card p-4'>
          <p class='text-sm text-card-foreground'>
            Card on <span class='font-mono text-xs'>bg-card</span>
          </p>
          <div class='
            mt-2 rounded-md bg-popover p-3 text-sm text-popover-foreground
          '>
            Popover on <span class='font-mono text-xs'>bg-popover</span>
          </div>
        </div>

        <div class='rounded-lg border border-border bg-sidebar p-4'>
          <p class='text-sm text-sidebar-foreground'>
            Sidebar on <span class='font-mono text-xs'>bg-sidebar</span>
          </p>
          <span
            class='
              mt-1 inline-block rounded-md bg-sidebar-accent px-2 py-1 text-xs
              text-sidebar-accent-foreground
            '
            >sidebar-accent</span
          >
          <span
            class='
              mt-1 inline-block rounded-md bg-sidebar-primary px-2 py-1 text-xs
              text-sidebar-primary-foreground
            '
            >sidebar-primary</span
          >
        </div>

        <div class='flex items-center gap-3'>
          <input
            type='text'
            placeholder='Input field'
            class='
              rounded-md border border-input bg-background px-3 py-1.5 text-sm
              text-foreground outline-outline
              placeholder:text-muted-foreground
            '
          />
          <Button>Button</Button>
        </div>
      </div>
    </section>
  </main>
</div>
